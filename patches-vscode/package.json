{
  "name": "patches-vscode",
  "displayName": "Patches DSL",
  "description": "Language support for the Patches audio DSL",
  "version": "0.0.1",
  "publisher": "vulpus-labs",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:patches"
  ],
  "contributes": {
    "commands": [
      {
        "command": "patches.showPatchGraph",
        "title": "Patches: Show Patch Graph",
        "category": "Patches"
      },
      {
        "command": "patches.rescanModules",
        "title": "Patches: Rescan Module Bundles",
        "category": "Patches"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "patches.showPatchGraph",
          "when": "resourceExtname == .patches",
          "group": "navigation"
        }
      ]
    },
    "languages": [
      {
        "id": "patches",
        "aliases": [
          "Patches",
          "patches"
        ],
        "extensions": [
          ".patches"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "patches",
        "scopeName": "source.patches",
        "path": "./syntaxes/patches.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Patches",
      "properties": {
        "patches.lsp.path": {
          "type": "string",
          "default": "",
          "description": "Path to the patches-lsp binary. Leave empty to use the bundled binary or PATH lookup."
        },
        "patches.modulePaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Directories or dylib files scanned at LSP start-up for FFI module bundles (.dylib/.so/.dll). Resolves external modules such as patches-vintage's VChorus/VBbd/VFlanger/VReverb so hover and diagnostics work in .patches files that reference them."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver-protocol": "^3.17.5"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
