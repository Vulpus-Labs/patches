pattern verse_drums {
    kick:  x . . . x . . .
    snare: . . x . . . x .
}

pattern fill_drums {
    kick:  x . x . x . x .
    snare: . x . x . x . x
}

pattern bass_a {
    note: C2 . . ~ E2 . G2 .
}

song my_song {
    | drums       | bass   |
    | verse_drums | bass_a |
    | verse_drums | bass_a |
    | fill_drums  | bass_a |
    | verse_drums | bass_a |
}

patch {
    module out : AudioOut
}
